---
import fs from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';
import matter from 'gray-matter';

const currentDir = path.dirname(fileURLToPath(import.meta.url));
const blogDir = currentDir;

const posts = fs
  .readdirSync(blogDir)
  .filter((file) => file.endsWith('.md'))
  .map((file) => {
    const fullPath = path.join(blogDir, file);
    const raw = fs.readFileSync(fullPath, 'utf-8');
    const { data } = matter(raw);
    const slug = file.replace(/\.md$/, '');
    const alternate = typeof data.alternate === 'string' ? data.alternate.trim() : '';
    const alternateSlug = alternate ? alternate.replace(/^\/blog\//, '').replace(/\/$/, '') : '';
    const hasAlternate = alternateSlug ? fs.existsSync(path.join(blogDir, `${alternateSlug}.md`)) : false;

    return {
      title: data.title ?? slug,
      url: `/blog/${slug}/`,
      pubDate: data.pubDate ? new Date(data.pubDate) : null,
      tags: Array.isArray(data.tags) ? data.tags : [],
      description: data.description ?? '',
      lang: data.lang ?? 'en',
      alternate,
      hasAlternate,
    };
  })
  .filter((post) => post.lang === 'en')
  .sort((a, b) => (b.pubDate?.getTime() ?? 0) - (a.pubDate?.getTime() ?? 0));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Writing | Lei Le</title>
    <meta name="description" content="Writing by Lei Le on AI, machine learning, engineering, and research ideas." />
    <style>
      :root {
        --bg: #f7f9fc;
        --surface: rgba(255, 255, 255, 0.9);
        --surface-strong: rgba(255, 255, 255, 0.97);
        --line: rgba(59, 130, 246, 0.16);
        --text: #0f172a;
        --muted: #64748b;
        --primary: #2563eb;
        --primary-strong: #1d4ed8;
        --accent: #0ea5e9;
        --shadow: 0 24px 60px rgba(37, 99, 235, 0.1);
      }
      body {
        margin: 0;
        padding: 32px 20px;
        background:
          radial-gradient(circle at 0% 0%, rgba(59, 130, 246, 0.1), transparent 26%),
          radial-gradient(circle at 100% 0%, rgba(14, 165, 233, 0.1), transparent 24%),
          radial-gradient(circle at 50% 100%, rgba(125, 211, 252, 0.08), transparent 26%),
          linear-gradient(180deg, #fdfeff 0%, #f4f8fc 100%);
        color: var(--text);
        font: 16px/1.85 Inter, ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      }
      .container { max-width: 960px; margin: 0 auto; }
      .hero, .card {
        background: linear-gradient(180deg, rgba(255,255,255,0.98), var(--surface));
        border: 1px solid var(--line);
        border-radius: 24px;
        padding: 28px;
        box-shadow: var(--shadow);
        backdrop-filter: blur(14px);
        position: relative;
        overflow: hidden;
      }
      .hero:before, .card:before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(59,130,246,0.05), rgba(14,165,233,0.04), transparent 52%);
        pointer-events: none;
      }
      .hero > *, .card > * { position: relative; z-index: 1; }
      .hero { margin-bottom: 24px; }
      .hero h1, .card h2 { letter-spacing: -0.04em; }
      .hero h1 { font-weight: 800; }
      .card { margin-bottom: 18px; }
      .meta { color: var(--muted); font-size: 14px; }
      .lang-note { margin-top: 10px; color: var(--muted); font-size: 14px; }
      .card p, .hero p { color: #334155; }
      a { color: var(--primary); text-decoration: none; }
      a:hover { color: var(--primary-strong); }
      .nav { margin-bottom: 20px; }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="nav"><a href="/">← Homepage</a></div>
      <div class="hero">
        <h1>Writing</h1>
        <p>A place for technical notes, research reflections, implementation details, and work in progress across AI, machine learning, and engineering.</p>
      </div>

      {posts.length > 0 ? posts.map((post) => (
        <div class="card">
          <h2><a href={post.url}>{post.title}</a></h2>
          <div class="meta">
            {post.pubDate ? post.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : ''}
            {post.tags.length ? ` · ${post.tags.join(' · ')}` : ''}
          </div>
          <p>{post.description}</p>
          {post.hasAlternate && <div class="lang-note">Chinese version available</div>}
        </div>
      )) : (
        <div class="card">
          <h2>Writing archive</h2>
          <div class="meta">Essays · Notes · Technical posts</div>
          <p>This space is reserved for future writing on AI, machine learning, systems, experiments, and engineering notes. New posts will appear here over time.</p>
        </div>
      )}
    </div>
  </body>
</html>
