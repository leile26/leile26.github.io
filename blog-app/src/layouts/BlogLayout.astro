---
import fs from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';

const frontmatter = Astro.props.frontmatter ?? Astro.props;
const { title, description, pubDate, tags = [], lang = 'en', alternate = '' } = frontmatter;

const currentDir = path.dirname(fileURLToPath(import.meta.url));
const blogDir = path.resolve(currentDir, '../pages/blog');
const normalizedAlternate = typeof alternate === 'string' ? alternate.trim() : '';
const alternateSlug = normalizedAlternate
  ? normalizedAlternate.replace(/^\/blog\//, '').replace(/\/$/, '')
  : '';
const hasAlternate = alternateSlug ? fs.existsSync(path.join(blogDir, `${alternateSlug}.md`)) : false;
const currentLang = lang === 'zh' ? '中文' : 'EN';
const otherLang = lang === 'zh' ? 'EN' : '中文';
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | Lei Le</title>
    <meta name="description" content={description || title} />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
    <style>
      :root {
        --bg: #f7f9fc;
        --surface: rgba(255, 255, 255, 0.9);
        --surface-strong: rgba(255, 255, 255, 0.97);
        --line: rgba(59, 130, 246, 0.16);
        --text: #0f172a;
        --muted: #64748b;
        --primary: #2563eb;
        --primary-strong: #1d4ed8;
        --accent: #0ea5e9;
        --shadow: 0 24px 60px rgba(37, 99, 235, 0.1);
      }
      body {
        margin: 0;
        padding: 32px 20px;
        background:
          radial-gradient(circle at 0% 0%, rgba(59, 130, 246, 0.1), transparent 26%),
          radial-gradient(circle at 100% 0%, rgba(14, 165, 233, 0.1), transparent 24%),
          radial-gradient(circle at 50% 100%, rgba(125, 211, 252, 0.08), transparent 26%),
          linear-gradient(180deg, #fdfeff 0%, #f4f8fc 100%);
        color: var(--text);
        font: 16px/1.85 Inter, ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      }
      .container {
        max-width: 840px;
        margin: 0 auto;
      }
      .card {
        background: linear-gradient(180deg, rgba(255,255,255,0.98), var(--surface));
        border: 1px solid var(--line);
        border-radius: 24px;
        padding: 32px;
        box-shadow: var(--shadow);
        backdrop-filter: blur(14px);
        position: relative;
        overflow: hidden;
      }
      .card:before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(59,130,246,0.05), rgba(14,165,233,0.04), transparent 52%);
        pointer-events: none;
      }
      .card > * {
        position: relative;
        z-index: 1;
      }
      h1 {
        letter-spacing: -0.04em;
        margin-bottom: 10px;
        font-weight: 800;
      }
      .meta {
        color: var(--muted);
        font-size: 14px;
        margin-bottom: 20px;
      }
      a { color: var(--primary); text-decoration: none; }
      a:hover { color: var(--primary-strong); }
      .tags { color: var(--muted); margin-top: 8px; }
      .lang-switch {
        margin-top: 18px;
        margin-bottom: 8px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px;
        border-radius: 999px;
        background: rgba(255,255,255,0.88);
        border: 1px solid var(--line);
        box-shadow: 0 10px 24px rgba(37, 99, 235, 0.06);
      }
      .lang-pill,
      .lang-switch a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 56px;
        padding: 8px 14px;
        border-radius: 999px;
        font-size: 14px;
        font-weight: 700;
      }
      .lang-pill {
        background: linear-gradient(180deg, rgba(37,99,235,0.12), rgba(14,165,233,0.08));
        color: var(--primary-strong);
      }
      .lang-switch a {
        color: var(--muted);
      }
      .lang-switch a:hover {
        color: var(--primary);
        background: rgba(37,99,235,0.06);
      }
      article { margin-top: 28px; }
      article p, article li { color: #334155; }
      pre {
        overflow-x: auto;
        padding: 16px;
        border-radius: 18px;
        background: linear-gradient(180deg, #0f172a, #111827);
        color: #e2e8f0;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.06), 0 12px 30px rgba(15, 23, 42, 0.14);
      }
      code { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }
      .nav { margin-bottom: 20px; }
      .nav a:first-child { margin-right: 6px; }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="nav"><a href="/">← Homepage</a> · <a href="/blog/">Archive</a></div>
      <div class="card">
        <h1>{title}</h1>
        <div class="meta">{pubDate?.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</div>
        {tags.length > 0 && <div class="tags">{tags.join(' · ')}</div>}
        {hasAlternate && (
          <div class="lang-switch">
            <span class="lang-pill">{currentLang}</span>
            <a href={alternate}>{otherLang}</a>
          </div>
        )}
        <article>
          <slot />
        </article>
      </div>
    </div>
  </body>
</html>
