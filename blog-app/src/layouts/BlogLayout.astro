---
const { title, description, pubDate, tags = [] } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | Lei Le</title>
    <meta name="description" content={description || title} />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
    <style>
      :root {
        --bg: #f7f9fc;
        --surface: #ffffff;
        --line: #e5eaf2;
        --text: #0f172a;
        --muted: #64748b;
        --primary: #2563eb;
      }
      body {
        margin: 0;
        padding: 32px 20px;
        background: linear-gradient(180deg, #fbfdff 0%, #f5f7fb 100%);
        color: var(--text);
        font: 16px/1.8 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      }
      .container {
        max-width: 840px;
        margin: 0 auto;
      }
      .card {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 20px;
        padding: 32px;
        box-shadow: 0 18px 44px rgba(15, 23, 42, 0.06);
      }
      .meta {
        color: var(--muted);
        font-size: 14px;
        margin-bottom: 20px;
      }
      a { color: var(--primary); text-decoration: none; }
      .tags { color: var(--muted); margin-top: 8px; }
      article { margin-top: 28px; }
      pre {
        overflow-x: auto;
        padding: 16px;
        border-radius: 14px;
        background: #0f172a;
        color: #e2e8f0;
      }
      code { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }
      .nav { margin-bottom: 20px; }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="nav"><a href="/">← Homepage</a> · <a href="/blog/">Archive</a></div>
      <div class="card">
        <h1>{title}</h1>
        <div class="meta">{pubDate?.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</div>
        {tags.length > 0 && <div class="tags">{tags.join(' · ')}</div>}
        <article>
          <slot />
        </article>
      </div>
    </div>
  </body>
</html>
